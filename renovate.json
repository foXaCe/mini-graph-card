{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "forkProcessing": "enabled",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    ":semanticCommitTypeAll(chore)",
    "group:allNonMajor",
    ":dependencyDashboard",
    ":timezone(Europe/Paris)"
  ],
  "labels": ["dependencies"],
  "assignees": ["foXaCe"],
  "rangeStrategy": "bump",
  "rebaseWhen": "behind-base-branch",
  "minimumReleaseAge": "3 days",
  "internalChecksFilter": "strict",
  "dependencyDashboard": true,
  "dependencyDashboardTitle": "📦 Renovate Dependency Dashboard",
  "dependencyDashboardLabels": ["dependencies", "dashboard"],
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "automerge": true,
  "automergeStrategy": "squash",
  "automergeType": "pr",
  "pruneStaleBranches": true,
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 6am on monday"],
    "automerge": true
  },
  "packageRules": [
    {
      "description": "Low-risk updates (patch / pin / digest) — auto-merge once CI is green",
      "matchUpdateTypes": ["patch", "pin", "digest"],
      "labels": ["dependencies", "auto-merge"]
    },
    {
      "description": "GitHub Actions — own label, auto-merge once CI is green",
      "matchManagers": ["github-actions"],
      "labels": ["dependencies", "github_actions"]
    },
    {
      "description": "Build / lint / test toolchain: skip MAJOR bumps (breaking — review manually). Minor & patch still flow and auto-merge.",
      "matchPackageNames": [
        "eslint",
        "typescript",
        "typescript-eslint",
        "rollup",
        "vitest",
        "jsdom",
        "globals",
        "tslib",
        "/^@rollup\\//",
        "/^@vitest\\//",
        "/^@typescript-eslint\\//"
      ],
      "matchUpdateTypes": ["major"],
      "enabled": false
    },
    {
      "description": "Major updates (non-toolchain): individual PR, still auto-merged when the full CI (lint + build + tests) passes",
      "matchUpdateTypes": ["major"],
      "labels": ["dependencies", "major"]
    }
  ],
  "ignorePaths": ["**/node_modules/**", "**/dist/**", "**/coverage/**"]
}
