{
  "name": "mini-graph-card",
  "version": "0.24.0",
  "description": "A minimalistic and customizable graph card for Home Assistant Lovelace UI",
  "type": "module",
  "keywords": [
    "home-assistant",
    "homeassistant",
    "hass",
    "automation",
    "lovelace",
    "sensor",
    "graph",
    "svg",
    "custom-cards"
  ],
  "main": "src/main.ts",
  "module": "src/main.ts",
  "repository": "git@github.com:foXaCe/mini-graph-card.git",
  "author": "Karl Kihlström <mrkihlstrom@gmail.com>",
  "license": "MIT",
  "engines": {
    "node": ">=24.18.0"
  },
  "dependencies": {
    "@kalkih/lz-string": "^1.4.5",
    "custom-card-helpers": "^2.0.0",
    "d3-interpolate": "^3.0.1",
    "lit": "^3.3.3",
    "localforage": "^1.10.0",
    "spark-md5": "^3.0.2"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.9",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^15.3.1",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/d3-interpolate": "^3.0.4",
    "@types/spark-md5": "^3.0.5",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9.39.4",
    "globals": "^15.15.0",
    "jsdom": "^25.0.1",
    "rollup": "^4.62.2",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "serialize-javascript": "^7.0.6"
  },
  "scripts": {
    "build": "rollup -c",
    "rollup": "rollup -c",
    "watch": "rollup -c --watch",
    "dev": "rollup -c --watch",
    "lint": "eslint \"src/**/*.{ts,js}\"",
    "lint:fix": "eslint \"src/**/*.{ts,js}\" --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "postversion": "npm run build",
    "hooks": "prek install"
  }
}
